{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && $code.matches(/^[0-9]{5}$/)",
        ".validate": "newData.hasChildren(['code','createdAt','hostClientId','status','currentRound'])",
        "code": {
          ".validate": "newData.isString() && newData.val() === $code"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        },
        "hostClientId": {
          ".validate": "newData.isString() && newData.val().length <= 80"
        },
        "hostName": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 40)"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() === 'lobby' || newData.val() === 'round_active' || newData.val() === 'round_stopped' || newData.val() === 'finished')"
        },
        "currentRound": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "roundStartedAt": {
          ".validate": "!newData.exists() || newData.isNumber()"
        },
        "roundStoppedAt": {
          ".validate": "!newData.exists() || newData.isNumber() || newData.val() === null"
        },
        "lastActionAt": {
          ".validate": "!newData.exists() || newData.isNumber()"
        },
        "teams": {
          "$teamId": {
            ".validate": "newData.hasChildren(['clientId','name','status','score','joinedAt'])",
            "clientId": {
              ".validate": "newData.isString() && newData.val().length <= 80"
            },
            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 40"
            },
            "status": {
              ".validate": "newData.isString() && (newData.val() === 'pending' || newData.val() === 'accepted' || newData.val() === 'rejected')"
            },
            "score": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "joinedAt": {
              ".validate": "newData.isNumber()"
            }
          }
        },
        "rounds": {
          "$round": {
            "$teamId": {
              ".validate": "newData.hasChildren(['teamId','teamName','answer','submittedAt','elapsedMs'])",
              "teamId": {
                ".validate": "newData.isString() && newData.val() === $teamId"
              },
              "teamName": {
                ".validate": "newData.isString() && newData.val().length <= 40"
              },
              "answer": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 300"
              },
              "submittedAt": {
                ".validate": "newData.isNumber()"
              },
              "elapsedMs": {
                ".validate": "newData.isNumber() && newData.val() >= 0"
              }
            }
          }
        }
      }
    }
  }
}
